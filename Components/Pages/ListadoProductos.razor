@page "/listado-productos"
@using ExamenFinal.Models
@using ExamenFinal.Services
@inject ProductosServices servicio

<div class="container mt-4">
    <div class="card shadow-sm">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Inventario de Productos</h3>

            <span class="badge bg-primary fs-5 p-2">
                Total Productos en Inventario: @totalProductos
            </span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">

                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Código</th>
                            <th>Nombre del Producto</th>
                            <th>Precio Base</th>
                            <th>Categoría y Detalles Específicos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (listaGeneral.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted p-4">
                                    No hay ningún producto registrado en el inventario.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var prod in listaGeneral)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@prod.codigoproducto</span></td>
                                    <td><strong>@prod.nombreproducto</strong></td>
                                    <td>Q @prod.precio</td>

                                    <td>
                                        @if (prod is Bebidas b)
                                        {
                                            <span class="text-info font-weight-bold">🥤 Bebida</span>
                                            <span class="text-muted"> | Volumen: @b.medida ml | Tipo: @b.tipobebida1</span>
                                        }
                                        else if (prod is PlatoFuerte pf)
                                        {
                                            <span class="text-warning font-weight-bold">🍖 Plato Fuerte</span>
                                            <span class="text-muted"> | Carne: @pf.Carne | Acompañamiento: @pf.Acompaniamiento1</span>
                                        }
                                        else if (prod is Postres po)
                                        {
                                            <span class="text-success font-weight-bold">🍰 Postre</span>
                                            <span class="text-muted"> | Azúcar: @(po.azucar ? "Sí" : "No") | Porción: @po.Tipoporcion1</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</div>

@code {
    // Lista unificada para meter todos los tipos de productos juntos
    private List<Productos> listaGeneral = new List<Productos>();
    private int totalProductos = 0;

    // OnInitialized se ejecuta automáticamente cuando se entra a la pantalla
    protected override void OnInitialized()
    {
        CargarDatosDesdeJson();
    }

    private void CargarDatosDesdeJson()
    {
        // 1. Jalamos el objeto contenedor con las 3 listas independientes
        ListaProductos datosJson = servicio.ObtenerListas();

        // 2. Calculamos el total sumando el Count de cada una (Puntos de la etiqueta)
        totalProductos = datosJson.Bebidas.Count +
                         datosJson.PlatoFuerte.Count +
                         datosJson.Postres.Count;

        // 3. Vaciamos y unificamos todo en nuestra lista general de tipo "Productos"
        listaGeneral = new List<Productos>();
        listaGeneral.AddRange(datosJson.Bebidas);
        listaGeneral.AddRange(datosJson.PlatoFuerte);
        listaGeneral.AddRange(datosJson.Postres);
    }
}